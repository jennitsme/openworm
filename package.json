{
  "name": "openworm",
  "version": "1.0.0",
  "description": "Developer-first agent framework (Node/TS) focused on DX: - Template library: RAG, browser automation, scheduled automation (one-command scaffold) - Local+cloud parity: develop in Docker, promote with the same manifest - Strong SDK: TypeScript-first with type-safe tool definitions; Python SDK planned - CLI + Web UI (planned): editor, logs, runbook recipes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openworm": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "server": "ts-node src/server.ts",
    "lint": "eslint ."
  },
  "keywords": [
    "agents",
    "ai",
    "cli",
    "openworm"
  ],
  "author": "openworm",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "autoprefixer": "^10.4.27",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "next": "^16.1.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19"
  }
}
